# Red Marker Configuration
# Copy this file to .env and customize as needed

# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Image Configuration
MAX_FILE_SIZE_MB=50
MARKER_RADIUS=15
MARKER_COLOR=red
MARKER_WIDTH=2

# Allowed Extensions (comma-separated)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# Temp Directory
TEMP_DIR=temp
